# Android package/version defaults used by build scripts and Gradle.
TW_APPLICATION_ID=org.trafficwrapper.app
TW_VERSION_CODE=1001
TW_VERSION_NAME=public-1.0.0
TW_PUBLIC_VERSION_NAME=

# Optional bootstrap enrollment secret embedded into BuildConfig. Usually empty
# for public platform builds.
TW_ENROLLMENT_SECRET=

# Android release signing. Generate your own keystore and keep passwords outside
# Git. TW_PUBLIC_SIGNING_CERT_SHA256 is the SHA-256 digest from apksigner.
TW_RELEASE_KEYSTORE=/absolute/path/to/release.jks
TW_RELEASE_KEY_ALIAS=trafficwrapper-release
TW_RELEASE_STORE_PASSWORD=
TW_RELEASE_KEY_PASSWORD=
TW_PUBLIC_SIGNING_CERT_SHA256=

# Docker/Android builder image override.
TW_ANDROID_IMAGE=trafficwrapper/android-builder:api36

# Update manifest generation.
TW_UPDATE_MANIFEST_KEY=/absolute/path/to/update.key
TW_UPDATE_OUT_DIR=build/update-release
TW_MIN_SUPPORTED_VERSION=1
TW_UPDATE_MANDATORY=false
TW_UPDATE_NOTES="Bug fixes and improvements."
TW_UPDATE_SEQ=

# Xray Android binary source override.
TW_XRAY_VERSION=v26.3.27
TW_XRAY_ASSET=Xray-android-arm64-v8a.zip
TW_XRAY_SHA256=57149ffd48b629c07bf76938e73ab2729fde5910091497eab3e93d1c190f4c1b
TW_XRAY_URL=https://github.com/XTLS/Xray-core/releases/download/v26.3.27/Xray-android-arm64-v8a.zip

# Advanced local build tuning.
CGO_LDFLAGS=
JAVA_OPTS=
GRADLE_OPTS=
DEFAULT_JVM_OPTS=

# Internal cache variables normally set by build scripts.
GRADLE_USER_HOME=
GOPATH=
GOCACHE=
GOMODCACHE=

# Advanced Docker build args for build/android.Dockerfile.
ANDROID_CMDLINE_TOOLS_ZIP=commandlinetools-linux-14742923_latest.zip
ANDROID_CMDLINE_TOOLS_SHA1=48833c34b761c10cb20bcd16582129395d121b27
ANDROID_NDK_VERSION=26.3.11579264
GOMOBILE_VERSION=a1d90793fc63015513ae877a689ddcc0903750ae

# Internal Android SDK paths set inside the builder image.
ANDROID_HOME=/opt/android-sdk
ANDROID_SDK_ROOT=/opt/android-sdk
ANDROID_NDK_HOME=/opt/android-sdk/ndk/26.3.11579264
